{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "typecheck": "yarn ts-check",
    "ts-check": "tsc --noEmit",
    "check": "yarn lint && yarn ts-check",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint --fix",
    "format": "prettier --write './**/*.{js,jsx,ts,tsx,css,md,json}' --config ./.prettierrc"
  },
  "dependencies": {
    "@apollo/client": "^4.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "cross-fetch": "4.1.0",
    "graphql": "16.8.1",
    "js-cookie": "3.0.5",
    "lint-staged": "16.0.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rxjs": "7.8.2",
    "ts-node": "10.9.2",
    "tsc-files": "1.1.4",
    "typescript": "6.0.2"
  },
  "devDependencies": {
    "eslint-config-prettier": "10.0.0",
    "eslint-plugin-prettier": "5.0.0",
    "husky": "9.0.11",
    "prettier": "3.0.1"
  },
  "resolutions": {
    "picomatch": "^4.0.4"
  }
}
