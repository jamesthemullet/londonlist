{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "typecheck": "yarn ts-check",
    "ts-check": "tsc --noEmit",
    "start": "next start",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check . && yarn ts-check",
    "check:fix": "biome check --write .",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@apollo/client": "^4.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "cross-fetch": "4.1.0",
    "graphql": "16.14.0",
    "js-cookie": "3.0.8",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "rxjs": "7.8.2",
    "ts-node": "10.9.2",
    "tsc-files": "1.1.4",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@biomejs/biome": "^2.0.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react-dom": "^19.0.0",
    "babel-jest": "^30.3.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.1.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  },
  "resolutions": {
    "picomatch": "^4.0.4"
  }
}
