{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "typecheck": "yarn ts-check",
    "ts-check": "tsc --noEmit",
    "check": "yarn lint && yarn ts-check",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint --fix",
    "format": "prettier --write './**/*.{js,jsx,ts,tsx,css,md,json}' --config ./.prettierrc",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@apollo/client": "^4.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "cross-fetch": "4.1.0",
    "graphql": "16.13.2",
    "js-cookie": "3.0.5",
    "lint-staged": "16.4.0",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "rxjs": "7.8.2",
    "ts-node": "10.9.2",
    "tsc-files": "1.1.4",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/parser": "^8.59.1",
    "babel-jest": "^30.3.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "3.8.3"
  },
  "resolutions": {
    "picomatch": "^4.0.4"
  }
}
