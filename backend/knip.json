{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/index.{js,ts}",
    "config/**/*.{js,ts}",
    "src/api/**/{controllers,routes,services}/**/*.{js,ts}"
  ],
  "project": [
    "src/**/*.{js,ts}",
    "config/**/*.{js,ts}"
  ],
  "ignore": ["src/admin/webpack.config.example.js"],
  "ignoreDependencies": [
    "@strapi/plugin-graphql",
    "@strapi/plugin-users-permissions",
    "better-sqlite3",
    "pg",
    "pg-connection-string"
  ]
}
